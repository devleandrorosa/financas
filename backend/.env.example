APP_NAME="Financas"
APP_ENV=local                  # produção: production
APP_KEY=                       # gerar com: php artisan key:generate
APP_DEBUG=true                 # produção: false
APP_URL=http://localhost        # produção: http://IP_DO_VPS (sem porta)

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack              # produção: stderr
LOG_LEVEL=debug                # produção: error

# ── Banco de dados ────────────────────────────────────────────────────
# Dev local (Docker)
DB_CONNECTION=pgsql
DB_HOST=postgres               # produção (VPS): postgres | produção (Supabase): aws-1-sa-east-1.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=financas
DB_USERNAME=financas
DB_PASSWORD=financas           # produção: senha forte
DB_SSLMODE=disable             # produção (Supabase): require | produção (VPS): disable

# ── Sessão, cache e fila ──────────────────────────────────────────────
SESSION_DRIVER=database        # produção: file
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis         # produção: database (sem Redis no VPS)
CACHE_STORE=database           # produção: file

# ── Redis (apenas dev local) ──────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── E-mail ────────────────────────────────────────────────────────────
MAIL_MAILER=smtp               # produção: log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@financas.app"
MAIL_FROM_NAME="${APP_NAME}"

# ── CORS ──────────────────────────────────────────────────────────────
# produção (mesmo servidor): deixe vazio
# produção (Vercel separado): https://financas.vercel.app
CORS_ALLOWED_ORIGINS=

# ── Inteligência Artificial ───────────────────────────────────────────
AI_PROVIDER=claude             # claude | gemini
ANTHROPIC_API_KEY=             # obter em: console.anthropic.com
GEMINI_API_KEY=                # obter em: aistudio.google.com
